# DecorFlow — environment template (copy to apps/api/.env for local)

# Server
NODE_ENV=development
PORT=5000

# Neon Postgres connection string (required)
# Example: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Logging
LOG_LEVEL=info

# Frontend origin allowed by CORS (use your Render URL in production)
CORS_ORIGIN=http://localhost:5173

# Frontend (apps/web/.env) — leave empty in production for same-origin /api/v1
# VITE_API_URL=http://localhost:5000
# VITE_APP_ENV=development
