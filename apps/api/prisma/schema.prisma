// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. CORE & SYSTEM
// ==========================================

model Company {
  id       String  @id @default(uuid())
  name     String
  email    String?
  phone    String?
  website  String?
  taxId    String?
  address  String?
  logoUrl  String?
  isActive Boolean @default(true)

  // Organization Settings
  timeZone String @default("UTC")
  currency String @default("USD")
  language String @default("en")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  branches             Branch[]
  users                User[]
  roles                Role[]
  customers            Customer[]
  events               Event[]
  eventTypes           EventType[]
  eventStatuses        EventStatus[]
  venues               Venue[]
  categories           InventoryCategory[]
  items                InventoryItem[]
  warehouses           Warehouse[]
  transactions         InventoryTransaction[]
  vehicles             Vehicle[]
  vehicleTypes         VehicleType[]
  drivers              Driver[]
  employees            Employee[]
  tasks                Task[]
  vendors              Vendor[]
  purchases            Purchase[]
  invoices             Invoice[]
  payments             Payment[]
  expenses             Expense[]
  activityLogs         ActivityLog[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  reminders            Reminder[]
  settings             Setting[]
  tags                 Tag[]
  comments             Comment[]
  packingJobs          PackingJob[]
  returnInspections    ReturnInspection[]
  cleaningJobs         CleaningJob[]
  repairJobs           RepairJob[]
  qualityChecks        QualityCheck[]
  trips                Trip[]
  teams                Team[]
  purchaseRequisitions PurchaseRequisition[]
  goodsReceipts        GoodsReceipt[]
  purchaseReturns      PurchaseReturn[]
  quotations           Quotation[]
  taxConfigs           TaxConfig[]
  vendorBills          VendorBill[]
  vendorPayments       VendorPayment[]
  savedReports         SavedReport[]
  scheduledReports     ScheduledReport[]

  // SaaS Relations
  subscription CompanySubscription?
  invitations  UserInvitation[]
}

model Branch {
  id        String  @id @default(uuid())
  companyId String
  name      String
  code      String?
  address   String?
  phone     String?
  email     String?
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users      User[]
  warehouses Warehouse[]
  events     Event[]
  vehicles   Vehicle[]
  employees  Employee[]
}

model User {
  id              String  @id @default(uuid())
  email           String  @unique
  passwordHash    String
  name            String
  avatarUrl       String?
  companyId       String?
  branchId        String?
  isActive        Boolean @default(true)
  isEmailVerified Boolean @default(false)
  isLocked        Boolean @default(false)
  isSuperAdmin    Boolean @default(false) // Platform-wide Super Admin

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  company              Company?                @relation(fields: [companyId], references: [id])
  branch               Branch?                 @relation(fields: [branchId], references: [id])
  roles                UserRole[]
  sessions             Session[]
  refreshTokens        RefreshToken[]
  passwordResets       PasswordResetToken[]
  employeeProfile      Employee?
  driverProfile        Driver?
  eventNotes           EventNote[]
  movements            InventoryMovement[]
  assignedTasks        TaskAssignment[]
  comments             Comment[]
  notifications        Notification[]
  createdNotifications Notification[]          @relation("NotificationCreator")
  preferences          NotificationPreference?
  packedJobs           PackingJob[]            @relation("PackedBy")
  verifiedJobs         PackingJob[]            @relation("VerifiedBy")
  dispatchedJobs       PackingJob[]            @relation("DispatchedBy")
  returnedJobs         PackingJob[]            @relation("ReturnedBy")
  inspections          ReturnInspection[]
  cleanedJobs          CleaningJob[]           @relation("CleanedBy")
  repairedJobs         RepairJob[]             @relation("RepairedBy")
  qualityChecks        QualityCheck[]
  Purchase             Purchase[]
  GoodsReceipt         GoodsReceipt[]
  approvedExpenses     Expense[]               @relation("ApprovedExpenses")
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  isSystem    Boolean @default(false)
  companyId   String?

  company     Company?         @relation(fields: [companyId], references: [id])
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  roles RolePermission[]
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

// Authentication Models
model Session {
  id           String   @id @default(uuid())
  userId       String
  ipAddress    String?
  userAgent    String?
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  sessionId String?
  isRevoked Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// System Logging & Meta
model Setting {
  id        String @id @default(uuid())
  companyId String
  key       String
  value     String // JSON stringified

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, key])
}

model ActivityLog {
  id         String   @id @default(uuid())
  companyId  String
  userId     String?
  action     String
  entityType String
  entityId   String
  details    String? // JSON stringified
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, entityType, entityId])
  @@index([companyId, createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  companyId String
  userId    String?
  tableName String
  recordId  String
  oldValues String? // JSON
  newValues String? // JSON
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
}

model Notification {
  id          String   @id @default(uuid())
  companyId   String
  userId      String
  title       String
  message     String
  type        String   @default("INFO") // SUCCESS, WARNING, ERROR, INFO
  icon        String?
  module      String? // CRM, FINANCE, EVENT, INVENTORY, WAREHOUSE, FLEET
  entityId    String?
  createdById String?
  priority    String   @default("LOW") // LOW, NORMAL, HIGH, URGENT
  link        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  company   Company @relation(fields: [companyId], references: [id])
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("NotificationCreator", fields: [createdById], references: [id])
}

model NotificationPreference {
  id                String  @id @default(uuid())
  userId            String  @unique
  emailEnabled      Boolean @default(true)
  smsEnabled        Boolean @default(false)
  inAppEnabled      Boolean @default(true)
  mutedModules      String? // JSON array
  priorityThreshold String  @default("LOW") // LOW, NORMAL, HIGH, URGENT

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reminder {
  id        String   @id @default(uuid())
  companyId String
  type      String // VEHICLE_SERVICE, INVENTORY_LOW, QUOTATION_EXPIRY, EVENT_UPCOMING
  entityId  String
  title     String
  dueDate   DateTime
  status    String   @default("PENDING") // PENDING, PROCESSED, CANCELLED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// Shared Models (Avoid generic Polymorphism)
model Attachment {
  id        String   @id @default(uuid())
  fileUrl   String
  fileName  String
  fileType  String
  size      Int
  createdAt DateTime @default(now())

  // Explicit optional foreign keys
  eventId    String?
  customerId String?
  purchaseId String?
  expenseId  String?

  event    Event?    @relation(fields: [eventId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  purchase Purchase? @relation(fields: [purchaseId], references: [id])
  expense  Expense?  @relation(fields: [expenseId], references: [id])
}

model Tag {
  id        String  @id @default(uuid())
  companyId String
  name      String
  color     String?

  // Explicit optional foreign keys
  eventId String?
  itemId  String?

  company Company        @relation(fields: [companyId], references: [id])
  event   Event?         @relation(fields: [eventId], references: [id])
  item    InventoryItem? @relation(fields: [itemId], references: [id])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  userId    String
  createdAt DateTime @default(now())

  // Explicit optional foreign keys
  eventId String?
  taskId  String?

  user      User     @relation(fields: [userId], references: [id])
  event     Event?   @relation(fields: [eventId], references: [id])
  task      Task?    @relation(fields: [taskId], references: [id])
  Company   Company? @relation(fields: [companyId], references: [id])
  companyId String?
}

// ==========================================
// 2. CRM
// ==========================================

model Customer {
  id        String  @id @default(uuid())
  companyId String
  type      String // INDIVIDUAL, BUSINESS
  name      String
  email     String?
  phone     String?
  taxId     String?
  notes     String?
  isActive  Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company     Company           @relation(fields: [companyId], references: [id])
  addresses   CustomerAddress[]
  contacts    CustomerContact[]
  events      Event[]
  quotations  Quotation[]
  invoices    Invoice[]
  attachments Attachment[]
}

model CustomerAddress {
  id         String  @id @default(uuid())
  customerId String
  type       String // BILLING, SHIPPING
  line1      String
  line2      String?
  city       String
  state      String
  zip        String
  country    String

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model CustomerContact {
  id         String  @id @default(uuid())
  customerId String
  name       String
  role       String?
  email      String?
  phone      String?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

// ==========================================
// 3. EVENTS
// ==========================================

model Event {
  id              String    @id @default(uuid())
  companyId       String
  branchId        String?
  customerId      String
  title           String
  typeId          String
  statusId        String
  theme           String?
  priority        String? // LOW, MEDIUM, HIGH
  startDate       DateTime
  endDate         DateTime
  setupDate       DateTime?
  dismantleDate   DateTime?
  startTime       String?
  endTime         String?
  guestCount      Int?
  budget          Float?
  expectedRevenue Float?
  venueId         String?
  totalAmount     Float     @default(0)
  depositAmount   Float     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company  Company     @relation(fields: [companyId], references: [id])
  branch   Branch?     @relation(fields: [branchId], references: [id])
  customer Customer    @relation(fields: [customerId], references: [id])
  type     EventType   @relation(fields: [typeId], references: [id])
  status   EventStatus @relation(fields: [statusId], references: [id])
  venue    Venue?      @relation(fields: [venueId], references: [id])

  notes             EventNote[]
  tasks             Task[]
  invoices          Invoice[]
  transactions      InventoryTransaction[]
  attachments       Attachment[]
  tags              Tag[]
  comments          Comment[]
  packingJobs       PackingJob[]
  returnInspections ReturnInspection[]
  trips             Trip[]
  eventAssignments  EventAssignment[]
  quotations        Quotation[]

  @@index([companyId, startDate, endDate])
  @@index([companyId, statusId])
}

model EventType {
  id        String  @id @default(uuid())
  companyId String
  name      String
  color     String?

  company Company @relation(fields: [companyId], references: [id])
  events  Event[]
}

model EventStatus {
  id         String  @id @default(uuid())
  companyId  String
  name       String
  color      String?
  isTerminal Boolean @default(false)

  company Company @relation(fields: [companyId], references: [id])
  events  Event[]
}

model EventNote {
  id        String   @id @default(uuid())
  eventId   String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  event  Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id])
}

model Venue {
  id               String  @id @default(uuid())
  companyId        String
  name             String
  type             String?
  address          String
  googleMapsUrl    String?
  coordinates      String?
  indoorOutdoor    String?
  parkingNotes     String?
  loadingNotes     String?
  siteInstructions String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company          Company @relation(fields: [companyId], references: [id])
  events           Event[]
  destinationTrips Trip[]  @relation("DestinationVenue")
}

// ==========================================
// 4. INVENTORY & WAREHOUSING
// ==========================================

model InventoryCategory {
  id          String  @id @default(uuid())
  companyId   String
  name        String
  description String?
  bufferHours Int     @default(0) // Default buffer turnaround time
  parentId    String?

  company  Company             @relation(fields: [companyId], references: [id])
  parent   InventoryCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children InventoryCategory[] @relation("CategoryHierarchy")
  items    InventoryItem[]
  subItems InventoryItem[]     @relation("Subcategory")
}

model InventoryItem {
  id              String  @id @default(uuid())
  companyId       String
  categoryId      String
  subcategoryId   String?
  name            String
  sku             String
  description     String?
  purchasePrice   Float   @default(0)
  rentalPrice     Float   @default(0)
  replacementCost Float   @default(0)

  barcode      String?
  qrCode       String?
  serialNumber String?
  batchNumber  String?
  unit         String?
  status       String  @default("AVAILABLE") // AVAILABLE, RESERVED, DAMAGED, RETIRED
  bufferHours  Int? // Overrides category default if set
  requiresCleaning Boolean @default(false) // Washable materials: cloths, carpets, chandarva, etc.

  currentQuantity   Int @default(0)
  availableQuantity Int @default(0)
  reservedQuantity  Int @default(0)
  damagedQuantity   Int @default(0)

  minStock Int     @default(0)
  maxStock Int?
  notes    String?

  isTracked Boolean @default(true)
  isActive  Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company     Company            @relation(fields: [companyId], references: [id])
  category    InventoryCategory  @relation(fields: [categoryId], references: [id])
  subcategory InventoryCategory? @relation("Subcategory", fields: [subcategoryId], references: [id])
  variants    InventoryVariant[]
  images      InventoryImage[]
  tags        Tag[]

  @@unique([companyId, sku])
  @@unique([companyId, qrCode])
  @@unique([companyId, barcode])
  @@index([companyId, categoryId])
  @@index([companyId, status])
}

model InventoryVariant {
  id     String @id @default(uuid())
  itemId String
  name   String
  sku    String @unique

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  locations               InventoryLocation[]
  movements               InventoryMovement[]
  conditions              InventoryCondition[]
  transactions            InventoryTransaction[]
  purchaseItems           PurchaseItem[]
  packingJobItems         PackingJobItem[]
  cleaningJobs            CleaningJob[]
  repairJobs              RepairJob[]
  PurchaseRequisitionItem PurchaseRequisitionItem[]
}

model InventoryImage {
  id        String  @id @default(uuid())
  itemId    String
  url       String
  isPrimary Boolean @default(false)

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

// Physical Warehousing
model Warehouse {
  id        String  @id @default(uuid())
  companyId String
  branchId  String?
  name      String
  address   String?
  isActive  Boolean @default(true)

  company              Company               @relation(fields: [companyId], references: [id])
  branch               Branch?               @relation(fields: [branchId], references: [id])
  zones                WarehouseZone[]
  packingJobs          PackingJob[]
  pickupTrips          Trip[]                @relation("PickupWarehouse")
  purchaseRequisitions PurchaseRequisition[]
  goodsReceipts        GoodsReceipt[]

  @@unique([companyId, name])
}

model WarehouseZone {
  id          String @id @default(uuid())
  warehouseId String
  name        String

  warehouse Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  racks     WarehouseRack[]
}

model WarehouseRack {
  id     String @id @default(uuid())
  zoneId String
  name   String

  zone    WarehouseZone    @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  shelves WarehouseShelf[]
}

model WarehouseShelf {
  id     String @id @default(uuid())
  rackId String
  name   String

  rack WarehouseRack  @relation(fields: [rackId], references: [id], onDelete: Cascade)
  bins WarehouseBin[]
}

model WarehouseBin {
  id      String @id @default(uuid())
  shelfId String
  name    String

  shelf     WarehouseShelf      @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  inventory InventoryLocation[]

  movementsFrom InventoryMovement[] @relation("FromBin")
  movementsTo   InventoryMovement[] @relation("ToBin")
}

// Stock Tracking
model InventoryLocation {
  id        String @id @default(uuid())
  variantId String
  binId     String
  quantity  Int    @default(0)

  variant InventoryVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  bin     WarehouseBin     @relation(fields: [binId], references: [id], onDelete: Cascade)

  @@unique([variantId, binId])
}

model InventoryMovement {
  id        String   @id @default(uuid())
  variantId String
  fromBinId String?
  toBinId   String?
  quantity  Int
  reason    String?
  userId    String
  createdAt DateTime @default(now())

  variant InventoryVariant @relation(fields: [variantId], references: [id])
  fromBin WarehouseBin?    @relation("FromBin", fields: [fromBinId], references: [id])
  toBin   WarehouseBin?    @relation("ToBin", fields: [toBinId], references: [id])
  user    User             @relation(fields: [userId], references: [id])
}

model InventoryCondition {
  id        String   @id @default(uuid())
  variantId String
  condition String // GOOD, DAMAGED, LOST
  quantity  Int
  notes     String?
  createdAt DateTime @default(now())

  variant InventoryVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model InventoryTransaction {
  id        String   @id @default(uuid())
  companyId String
  variantId String
  type      String // IN, OUT
  quantity  Int
  eventId   String?
  createdAt DateTime @default(now())

  company Company          @relation(fields: [companyId], references: [id])
  variant InventoryVariant @relation(fields: [variantId], references: [id])
  event   Event?           @relation(fields: [eventId], references: [id])
}

// ==========================================
// 5. FLEET (VEHICLES)
// ==========================================

model Vehicle {
  id             String  @id @default(uuid())
  companyId      String
  branchId       String?
  typeId         String
  make           String
  model          String
  year           Int?
  licensePlate   String
  capacity       Float?
  weightCapacity Float?
  volumeCapacity Float?
  status         String // ACTIVE, MAINTENANCE, RETIRED

  insuranceExpiry  DateTime?
  fitnessExpiry    DateTime?
  serviceDueDate   DateTime?
  odometerReading  Float?
  fuelType         String?
  assignedDriverId String?
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company        Company      @relation(fields: [companyId], references: [id])
  branch         Branch?      @relation(fields: [branchId], references: [id])
  type           VehicleType  @relation(fields: [typeId], references: [id])
  packingJobs    PackingJob[]
  trips          Trip[]
  assignedDriver Driver?      @relation("VehicleDriver", fields: [assignedDriverId], references: [id])
}

model VehicleType {
  id        String @id @default(uuid())
  companyId String
  name      String

  company  Company   @relation(fields: [companyId], references: [id])
  vehicles Vehicle[]
}

model Driver {
  id                 String   @id @default(uuid())
  companyId          String
  userId             String   @unique
  licenseNumber      String
  licenseExpiry      DateTime
  contactNumber      String?
  emergencyContact   String?
  availabilityStatus String   @default("AVAILABLE") // AVAILABLE, ON_TRIP, ON_LEAVE
  notes              String?

  company          Company      @relation(fields: [companyId], references: [id])
  user             User         @relation(fields: [userId], references: [id])
  packingJobs      PackingJob[]
  trips            Trip[]
  assignedVehicles Vehicle[]    @relation("VehicleDriver")
}

// ==========================================
// 6. HR (EMPLOYEES)
// ==========================================

model Employee {
  id               String    @id @default(uuid())
  companyId        String
  branchId         String?
  userId           String    @unique
  employeeCode     String?
  department       String?
  position         String?
  joinDate         DateTime?
  salary           Float?
  status           String // ACTIVE, ON_LEAVE, TERMINATED
  skills           String? // comma separated
  certifications   String? // comma separated
  contactNumber    String?
  emergencyContact String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company              Company               @relation(fields: [companyId], references: [id])
  branch               Branch?               @relation(fields: [branchId], references: [id])
  user                 User                  @relation(fields: [userId], references: [id])
  attendance           EmployeeAttendance[]
  ledTeams             Team[]                @relation("TeamLeader")
  teamMemberships      Team[]                @relation("TeamMembers")
  eventAssignments     EventAssignment[]
  purchaseRequisitions PurchaseRequisition[]
}

model EmployeeAttendance {
  id            String    @id @default(uuid())
  employeeId    String
  date          DateTime
  checkIn       DateTime?
  checkOut      DateTime?
  shiftStart    DateTime?
  shiftEnd      DateTime?
  overtimeHours Float?
  status        String // PRESENT, ABSENT, HALF_DAY

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
}

// ==========================================
// 7. OPERATIONS
// ==========================================

model Task {
  id          String    @id @default(uuid())
  companyId   String
  eventId     String?
  title       String
  description String?
  status      String // TODO, IN_PROGRESS, DONE
  priority    String // LOW, MEDIUM, HIGH
  progress    Int       @default(0)
  dueDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company             @relation(fields: [companyId], references: [id])
  event       Event?              @relation(fields: [eventId], references: [id])
  assignments TaskAssignment[]
  checklists  TaskChecklistItem[]
  comments    Comment[]

  @@index([companyId, status])
}

model TaskAssignment {
  id         String @id @default(uuid())
  taskId     String
  assigneeId String

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignee User @relation(fields: [assigneeId], references: [id])

  @@unique([taskId, assigneeId])
}

model TaskChecklistItem {
  id          String  @id @default(uuid())
  taskId      String
  title       String
  isCompleted Boolean @default(false)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Team {
  id          String  @id @default(uuid())
  companyId   String
  name        String
  description String?
  leaderId    String?
  capacity    Int?
  skills      String? // comma separated

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id])
  leader           Employee?         @relation("TeamLeader", fields: [leaderId], references: [id])
  members          Employee[]        @relation("TeamMembers")
  eventAssignments EventAssignment[]
}

model EventAssignment {
  id            String    @id @default(uuid())
  eventId       String
  employeeId    String?
  teamId        String?
  role          String
  reportingTime DateTime?
  setupTime     DateTime?
  eventDuty     String // SETUP, DISMANTLING, BOTH
  status        String // PENDING, COMPLETED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  employee Employee? @relation(fields: [employeeId], references: [id])
  team     Team?     @relation(fields: [teamId], references: [id])
}

// ==========================================
// 8. PROCUREMENT
// ==========================================

model Vendor {
  id            String  @id @default(uuid())
  companyId     String
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  taxId         String? // GST
  panNumber     String?
  bankDetails   String? // JSON or text
  categories    String? // comma separated
  rating        Float   @default(0)
  isPreferred   Boolean @default(false)
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company      @relation(fields: [companyId], references: [id])
  purchases   Purchase[]
  vendorBills VendorBill[]
}

model Purchase {
  id               String    @id @default(uuid())
  companyId        String
  vendorId         String
  date             DateTime
  expectedDelivery DateTime?
  totalAmount      Float     @default(0)
  tax              Float     @default(0)
  discount         Float     @default(0)
  status           String // DRAFT, PENDING_APPROVAL, APPROVED, ORDERED, PARTIAL_RECEIPT, RECEIVED, CANCELLED
  approvedById     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company         Company          @relation(fields: [companyId], references: [id])
  vendor          Vendor           @relation(fields: [vendorId], references: [id])
  approvedBy      User?            @relation(fields: [approvedById], references: [id])
  items           PurchaseItem[]
  attachments     Attachment[]
  goodsReceipts   GoodsReceipt[]
  purchaseReturns PurchaseReturn[]
  vendorBills     VendorBill[]

  @@index([companyId, status])
}

model PurchaseItem {
  id         String @id @default(uuid())
  purchaseId String
  variantId  String
  quantity   Int
  unitPrice  Float

  purchase Purchase           @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  variant  InventoryVariant   @relation(fields: [variantId], references: [id])
  grnItems GoodsReceiptItem[]
}

model PurchaseRequisition {
  id            String   @id @default(uuid())
  companyId     String
  requestedById String
  warehouseId   String
  requiredDate  DateTime
  priority      String // LOW, MEDIUM, HIGH
  notes         String?
  status        String // PENDING, APPROVED, REJECTED, ORDERED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company                   @relation(fields: [companyId], references: [id])
  requestedBy Employee                  @relation(fields: [requestedById], references: [id])
  warehouse   Warehouse                 @relation(fields: [warehouseId], references: [id])
  items       PurchaseRequisitionItem[]
}

model PurchaseRequisitionItem {
  id            String @id @default(uuid())
  requisitionId String
  variantId     String
  quantity      Int

  requisition PurchaseRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  variant     InventoryVariant    @relation(fields: [variantId], references: [id])
}

model GoodsReceipt {
  id           String   @id @default(uuid())
  companyId    String
  purchaseId   String
  warehouseId  String
  receivedById String
  receivedDate DateTime @default(now())
  status       String // DRAFT, COMPLETED, CANCELLED
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company            @relation(fields: [companyId], references: [id])
  purchase   Purchase           @relation(fields: [purchaseId], references: [id])
  warehouse  Warehouse          @relation(fields: [warehouseId], references: [id])
  receivedBy User               @relation(fields: [receivedById], references: [id])
  items      GoodsReceiptItem[]
}

model GoodsReceiptItem {
  id                 String  @id @default(uuid())
  grnId              String
  purchaseItemId     String
  receivedQuantity   Int
  damagedQuantity    Int     @default(0)
  shortQuantity      Int     @default(0)
  passedQualityCheck Boolean @default(true)

  grn          GoodsReceipt @relation(fields: [grnId], references: [id], onDelete: Cascade)
  purchaseItem PurchaseItem @relation(fields: [purchaseItemId], references: [id])
}

model PurchaseReturn {
  id           String   @id @default(uuid())
  companyId    String
  purchaseId   String
  returnDate   DateTime @default(now())
  reason       String
  refundAmount Float    @default(0)
  status       String // PENDING, PROCESSING, COMPLETED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id])
  purchase Purchase @relation(fields: [purchaseId], references: [id])
}

// ==========================================
// 9. FINANCE
// ==========================================

model Invoice {
  id            String   @id @default(uuid())
  companyId     String
  customerId    String
  eventId       String?
  quotationId   String?  @unique
  number        String
  date          DateTime
  dueDate       DateTime
  subTotal      Float    @default(0)
  taxTotal      Float    @default(0)
  discountTotal Float    @default(0)
  totalAmount   Float
  status        String // DRAFT, SENT, PARTIAL, PAID, OVERDUE, CANCELLED
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company       @relation(fields: [companyId], references: [id])
  customer  Customer      @relation(fields: [customerId], references: [id])
  event     Event?        @relation(fields: [eventId], references: [id])
  quotation Quotation?    @relation(fields: [quotationId], references: [id])
  items     InvoiceItem[]
  payments  Payment[]

  @@unique([companyId, number])
  @@index([companyId, status])
  @@index([companyId, date])
}

model InvoiceItem {
  id          String @id @default(uuid())
  invoiceId   String
  description String
  quantity    Int
  unitPrice   Float
  taxRate     Float  @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String   @id @default(uuid())
  companyId String
  invoiceId String
  amount    Float
  date      DateTime
  method    String // CASH, CARD, TRANSFER, CHEQUE
  reference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model Expense {
  id           String   @id @default(uuid())
  companyId    String
  category     String // FUEL, MAINTENANCE, SUPPLIES, OTHER
  amount       Float
  date         DateTime
  description  String?
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED, PAID
  approvedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company      @relation(fields: [companyId], references: [id])
  approvedBy  User?        @relation("ApprovedExpenses", fields: [approvedById], references: [id])
  attachments Attachment[]
}

model Quotation {
  id            String   @id @default(uuid())
  companyId     String
  customerId    String
  eventId       String?
  number        String
  date          DateTime
  validUntil    DateTime
  subTotal      Float    @default(0)
  taxTotal      Float    @default(0)
  discountTotal Float    @default(0)
  totalAmount   Float
  status        String // DRAFT, SENT, APPROVED, REJECTED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company         @relation(fields: [companyId], references: [id])
  customer Customer        @relation(fields: [customerId], references: [id])
  event    Event?          @relation(fields: [eventId], references: [id])
  items    QuotationItem[]
  invoice  Invoice?

  @@unique([companyId, number])
  @@index([companyId, status])
}

model QuotationItem {
  id          String @id @default(uuid())
  quotationId String
  description String
  quantity    Int
  unitPrice   Float
  taxRate     Float  @default(0)

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model VendorBill {
  id          String   @id @default(uuid())
  companyId   String
  vendorId    String
  purchaseId  String?
  billNumber  String
  date        DateTime
  dueDate     DateTime
  totalAmount Float
  status      String // PENDING, PARTIAL, PAID, CANCELLED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company         @relation(fields: [companyId], references: [id])
  vendor   Vendor          @relation(fields: [vendorId], references: [id])
  purchase Purchase?       @relation(fields: [purchaseId], references: [id])
  payments VendorPayment[]

  @@unique([companyId, billNumber])
}

model VendorPayment {
  id           String   @id @default(uuid())
  companyId    String
  vendorBillId String
  amount       Float
  date         DateTime
  method       String // CASH, CARD, TRANSFER, CHEQUE
  reference    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company    @relation(fields: [companyId], references: [id])
  vendorBill VendorBill @relation(fields: [vendorBillId], references: [id])
}

model TaxConfig {
  id        String  @id @default(uuid())
  companyId String
  name      String
  rate      Float
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ==========================================
// 10. WAREHOUSE EXECUTION WORKFLOW
// ==========================================

model PackingJob {
  id          String  @id @default(uuid())
  companyId   String
  eventId     String
  warehouseId String?
  status      String  @default("PENDING") // PENDING, PACKING, PACKED, VERIFIED, DISPATCHED, RETURNED, ARCHIVED

  packedById String?
  packedAt   DateTime?

  verifiedById      String?
  verifiedAt        DateTime?
  verificationNotes String?

  dispatchedById    String?
  dispatchedAt      DateTime?
  dispatchNotes     String?
  vehicleId         String?
  driverId          String?
  dispatchChecklist String? // JSON

  returnedById String?
  returnedAt   DateTime?
  returnNotes  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company      Company    @relation(fields: [companyId], references: [id])
  event        Event      @relation(fields: [eventId], references: [id])
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])
  packedBy     User?      @relation("PackedBy", fields: [packedById], references: [id])
  verifiedBy   User?      @relation("VerifiedBy", fields: [verifiedById], references: [id])
  dispatchedBy User?      @relation("DispatchedBy", fields: [dispatchedById], references: [id])
  returnedBy   User?      @relation("ReturnedBy", fields: [returnedById], references: [id])
  vehicle      Vehicle?   @relation(fields: [vehicleId], references: [id])
  driver       Driver?    @relation(fields: [driverId], references: [id])

  items             PackingJobItem[]
  returnInspections ReturnInspection[]
}

model PackingJobItem {
  id           String @id @default(uuid())
  packingJobId String
  variantId    String

  expectedQuantity Int
  pickedQuantity   Int     @default(0)
  missingQuantity  Int     @default(0)
  damagedQuantity  Int     @default(0)
  packingNotes     String?

  returnedQuantity      Int     @default(0)
  returnMissingQuantity Int     @default(0)
  returnDamagedQuantity Int     @default(0)
  needsCleaningQuantity Int     @default(0)
  needsRepairQuantity   Int     @default(0)
  returnNotes           String?

  packingJob            PackingJob             @relation(fields: [packingJobId], references: [id], onDelete: Cascade)
  variant               InventoryVariant       @relation(fields: [variantId], references: [id])
  returnInspectionItems ReturnInspectionItem[]
}

// ==========================================
// 11. MAINTENANCE, CLEANING & REPAIRS
// ==========================================

model ReturnInspection {
  id              String  @id @default(uuid())
  companyId       String
  eventId         String
  packingJobId    String
  inspectorId     String
  status          String  @default("PENDING") // PENDING, COMPLETED
  inspectionNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company    @relation(fields: [companyId], references: [id])
  event      Event      @relation(fields: [eventId], references: [id])
  packingJob PackingJob @relation(fields: [packingJobId], references: [id])
  inspector  User       @relation(fields: [inspectorId], references: [id])

  items ReturnInspectionItem[]
}

model ReturnInspectionItem {
  id                 String @id @default(uuid())
  returnInspectionId String
  packingJobItemId   String

  returnedQuantity Int     @default(0)
  missingQuantity  Int     @default(0)
  damagedQuantity  Int     @default(0)
  dirtyQuantity    Int     @default(0)
  lostQuantity     Int     @default(0)
  inspectionNotes  String?

  returnInspection ReturnInspection @relation(fields: [returnInspectionId], references: [id], onDelete: Cascade)
  packingJobItem   PackingJobItem   @relation(fields: [packingJobItemId], references: [id])

  cleaningJobs  CleaningJob[]
  repairJobs    RepairJob[]
  qualityChecks QualityCheck[]
}

model CleaningJob {
  id               String @id @default(uuid())
  companyId        String
  inspectionItemId String
  variantId        String

  priority     String    @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  status       String    @default("PENDING") // PENDING, CLEANING, DONE
  quantity     Int
  washCount    Int       @default(0)
  lastWashDate DateTime?
  dueDate      DateTime?

  assignedStaffId String?
  cleaningNotes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company        Company              @relation(fields: [companyId], references: [id])
  inspectionItem ReturnInspectionItem @relation(fields: [inspectionItemId], references: [id])
  variant        InventoryVariant     @relation(fields: [variantId], references: [id])
  assignedStaff  User?                @relation("CleanedBy", fields: [assignedStaffId], references: [id])
}

model RepairJob {
  id               String @id @default(uuid())
  companyId        String
  inspectionItemId String
  variantId        String

  damageCategory     String
  repairPriority     String    @default("NORMAL")
  status             String    @default("PENDING") // PENDING, REPAIRING, DONE
  quantity           Int
  cost               Float?    @default(0)
  expectedCompletion DateTime?

  assignedTechnicianId String?
  repairNotes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company            Company              @relation(fields: [companyId], references: [id])
  inspectionItem     ReturnInspectionItem @relation(fields: [inspectionItemId], references: [id])
  variant            InventoryVariant     @relation(fields: [variantId], references: [id])
  assignedTechnician User?                @relation("RepairedBy", fields: [assignedTechnicianId], references: [id])
}

model QualityCheck {
  id               String @id @default(uuid())
  companyId        String
  inspectionItemId String
  inspectorId      String

  status String // PASS, MINOR_ISSUE, REPAIR_AGAIN, DISCARD
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company        Company              @relation(fields: [companyId], references: [id])
  inspectionItem ReturnInspectionItem @relation(fields: [inspectionItemId], references: [id])
  inspector      User                 @relation(fields: [inspectorId], references: [id])
}

// ==========================================
// 12. LOGISTICS & DISPATCH
// ==========================================

model Trip {
  id                 String  @id @default(uuid())
  companyId          String
  eventId            String
  vehicleId          String
  driverId           String
  pickupWarehouseId  String?
  destinationVenueId String?

  plannedDeparture DateTime?
  plannedArrival   DateTime?
  actualDeparture  DateTime?
  actualArrival    DateTime?

  status   String // PENDING, DISPATCHED, COMPLETED, CANCELLED
  distance Float?
  notes    String?

  // Pre-Dispatch Checklist
  checkVehicleInspection Boolean @default(false)
  checkFuel              Boolean @default(false)
  checkDocuments         Boolean @default(false)
  checkLoadVerification  Boolean @default(false)
  checkSafetyEquipment   Boolean @default(false)

  // Post-Return Checklist
  postVehicleInspection Boolean @default(false)
  postDamageReport      Boolean @default(false)
  postFuelLog           Boolean @default(false)
  postOdometerUpdate    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company          Company    @relation(fields: [companyId], references: [id])
  event            Event      @relation(fields: [eventId], references: [id])
  vehicle          Vehicle    @relation(fields: [vehicleId], references: [id])
  driver           Driver     @relation(fields: [driverId], references: [id])
  pickupWarehouse  Warehouse? @relation("PickupWarehouse", fields: [pickupWarehouseId], references: [id])
  destinationVenue Venue?     @relation("DestinationVenue", fields: [destinationVenueId], references: [id])
}

// ==========================================
// 12. REPORTS & ANALYTICS
// ==========================================

model SavedReport {
  id        String @id @default(uuid())
  companyId String
  name      String
  type      String // FINANCIAL, INVENTORY, EVENT, WORKFORCE, CUSTOMER
  config    String // JSON containing filters, columns, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company           @relation(fields: [companyId], references: [id])
  schedules ScheduledReport[]
}

model ScheduledReport {
  id        String    @id @default(uuid())
  companyId String
  reportId  String
  frequency String // DAILY, WEEKLY, MONTHLY
  emails    String // JSON array of emails
  isActive  Boolean   @default(true)
  lastRunAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company     @relation(fields: [companyId], references: [id])
  report  SavedReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

// ==========================================
// 13. SAAS & MULTI-TENANT
// ==========================================

model SubscriptionPlan {
  id           String @id @default(uuid())
  name         String // Free Trial, Basic, Professional, Enterprise
  price        Float
  billingCycle String // MONTHLY, YEARLY
  maxUsers     Int
  maxEvents    Int
  features     String // JSON array of enabled features e.g. ["CRM", "FINANCE", "FLEET"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions CompanySubscription[]
}

model CompanySubscription {
  id          String   @id @default(uuid())
  companyId   String   @unique
  planId      String
  status      String // ACTIVE, PAST_DUE, CANCELLED
  startDate   DateTime @default(now())
  renewalDate DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan    SubscriptionPlan @relation(fields: [planId], references: [id])
}

model UserInvitation {
  id        String   @id @default(uuid())
  companyId String
  email     String
  roleId    String? // Optional specific role assignment
  token     String   @unique
  status    String   @default("PENDING") // PENDING, ACCEPTED, EXPIRED
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
